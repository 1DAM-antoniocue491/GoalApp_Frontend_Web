# Configuración de GoalApp Frontend
# Copia este archivo como .env y configura las variables necesarias

# URL del API Backend (producción)
VITE_API_URL=https://goalapp-backend-j2cx.onrender.com/api/v1

# URL del API Backend (desarrollo local)
# VITE_API_URL=http://localhost:8000/api/v1

# Usar datos mock en lugar de la API real (true/false)
# Cambiar a false cuando el backend este disponible
VITE_USE_MOCKS=true

# Configuración opcional de autenticación
# VITE_TOKEN_KEY=goalapp_token
# VITE_REFRESH_TOKEN_KEY=goalapp_refresh_token